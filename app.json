{
  "expo": {
    "name": "d10-mobile",
    "slug": "d10-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.d10therapeutics.mobiledemo",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "D-10 Therapeutics connects to your wearable to read live vital snapshots during monitoring.",
        "NSBluetoothPeripheralUsageDescription": "D-10 Therapeutics uses Bluetooth to communicate with your wearable for live vital readings."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "neverForLocation": true
        }
      ],
      "expo-font"
    ]
  }
}
